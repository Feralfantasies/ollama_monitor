#!/usr/bin/env bash
set -euo pipefail

# ── Color helpers ──
red()    { printf "\033[0;31m%s\033[0m\n" "$*"; }
green()  { printf "\033[0;32m%s\033[0m\n" "$*"; }
yellow() { printf "\033[1;33m%s\033[0m\n" "$*"; }
cyan()   { printf "\033[0;36m%s\033[0m\n" "$*"; }

FAIL=0

echo ""
cyan "===== Pre-commit checks ====="
echo ""

# 1. rustfmt — format all workspace files
yellow "Running cargo fmt --check ..."
if cargo fmt --check; then
    green "✓  Format OK"
else
    red "✗  Formatting issues found. Run \`cargo fmt\` to fix."
    FAIL=1
fi

# 2. clippy — lint with denied warnings
yellow "Running cargo clippy ..."
if cargo clippy -- -D warnings; then
    green "✓  Clippy OK"
else
    red "✗  Clippy found warnings/errors. Fix them before committing."
    FAIL=1
fi

# 3. cargo test — run unit / doc tests
yellow "Running cargo test ..."
if cargo test; then
    green "✓  Tests passed"
else
    red "✗  Tests failed. Fix the failures before committing."
    FAIL=1
fi

# ── Gate the commit ──
echo ""
if [ "$FAIL" -ne 0 ]; then
    red "Pre-commit checks failed. Commit aborted."
    echo ""
    exit 1
fi

green "All pre-commit checks passed."
echo ""
exit 0
